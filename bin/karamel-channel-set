#!/bin/bash

if (($# == 0)); then
  echo "Usage: karamel-channel-set [stable|edge|dev]"
  exit 1
else
  channel="$1"
fi

case "$channel" in
"stable") karamel-branch-set "master" && karamel-refresh-pacman "stable" ;;
"edge") karamel-branch-set "master" && karamel-refresh-pacman "edge" ;;
"dev") karamel-branch-set "dev" && karamel-refresh-pacman "edge" ;;
*) echo "Unknown channel: $channel"; exit 1; ;;
esac

karamel-update -y
