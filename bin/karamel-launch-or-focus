#!/bin/bash

if (($# == 0)); then
  echo "Usage: karamel-launch-or-focus [window-pattern] [launch-command]"
  exit 1
fi

WINDOW_PATTERN="$1"
LAUNCH_COMMAND="${2:-"uwsm-app -- $WINDOW_PATTERN"}"

# Get window list from Niri
WINDOW_ID=$(niri msg -j windows | jq -r --arg p "$WINDOW_PATTERN" '.[]|select((.app_id|test($p;"i")) or (.title|test($p;"i")))|.id' | head -n1)

if [[ -n $WINDOW_ID ]]; then
  niri msg action focus-window --id "$WINDOW_ID"
else
  eval exec setsid $LAUNCH_COMMAND
fi
