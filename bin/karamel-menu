show_system_menu() {
  case $(menu "System" "ï€£  Lock\nَ±„„  Screensaver\nَ°œ‰  Restart\nَ°گ¥  Shutdown") in
  *Lock*) karamel-lock-screen ;;
  *Screensaver*) karamel-launch-screensaver force ;;
  *Restart*) karamel-cmd-reboot ;;
  *Shutdown*) karamel-cmd-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "َ°€»  Apps\nَ°§‘  Learn\nَ±“‍  Trigger\nî¯ڈ  Style\nîک•  Setup\nَ°‰‰  Install\nَ°­Œ  Remove\nï€،  Update\nî©´  About\nï€‘  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "Launchâ€¦" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *share*) show_share_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenshot*) show_screenshot_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) karamel-launch-about ;;
  *system*) show_system_menu ;;
  esac
}

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
