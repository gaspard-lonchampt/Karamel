#!/bin/bash

export PATH="$HOME/.local/share/karamel/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | karamel-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptâ€¦" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.karamel.terminal "$@"
}

present_terminal() {
  karamel-launch-floating-terminal-with-presentation $1
}

open_in_editor() {
  notify-send "Editing config file" "$1"
  karamel-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm --needed $2 && sleep 2 && karamel-font-set '$3'"
}

install_terminal() {
  present_terminal "karamel-install-terminal $1"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; yay -S --noconfirm $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; yay -S --noconfirm $2 && setsid gtk-launch $3"
}

show_learn_menu() {
  case $(menu "Learn" "ï„œ  Keybindings\nïگ…  Karamel\nïچ™  Niri\nَ°£‡  Arch\nîڑ®  Neovim\nَ±†ƒ  Bash") in
  *Keybindings*) karamel-menu-keybindings ;;
  *Karamel*) karamel-launch-webapp "https://learn.omacom.io/2/the-karamel-manual" ;;
  *Niri*) karamel-launch-webapp "https://github.com/YaLTeR/niri/wiki/" ;;
  *Arch*) karamel-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) karamel-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) karamel-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "ï€°  Capture\nï”ژ  Share\nَ°”ژ  Toggle") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "ï€°  Screenshot\nï€½  Screenrecord\nَ°ƒ‰  Color") in
  *Screenshot*) show_screenshot_menu ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) wl-color-picker ;;
  *) show_trigger_menu ;;
  esac
}

show_screenshot_menu() {
  case $(menu "Screenshot" "ï€°  Snap with Editing\nï€°  Straight to Clipboard") in
  *Editing*) karamel-cmd-screenshot smart ;;
  *Clipboard*) karamel-cmd-screenshot smart clipboard ;;
  *) show_capture_menu ;;
  esac
}

show_screenrecord_menu() {
  karamel-cmd-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "ï€½  With desktop audio\nï€½  With desktop + microphone audio\nï€½  With desktop + microphone audio + webcam") in
  *"With desktop audio") karamel-cmd-screenrecord --with-desktop-audio ;;
  *"With desktop + microphone audio") karamel-cmd-screenrecord --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam") karamel-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "ïپ؟  Clipboard\nî©»  File \nï„”  Folder") in
  *Clipboard*) karamel-cmd-share clipboard ;;
  *File*) terminal bash -c "karamel-cmd-share file" ;;
  *Folder*) terminal bash -c "karamel-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "َ±„„  Screensaver\nَ°”ژ  Nightlight\nَ±«–  Idle Lock\nَ°چœ  Top Bar") in
  *Screensaver*) karamel-toggle-screensaver ;;
  *Nightlight*) karamel-toggle-nightlight ;;
  *Idle*) karamel-toggle-idle ;;
  *Bar*) karamel-toggle-waybar ;;
  *) show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "َ°¸Œ  Theme\nî™™  Font\nï€¾  Background\nïچ™  Niri\nَ±„„  Screensaver\nî©´  About") in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) karamel-theme-bg-next ;;
  *Niri*) open_in_editor ~/.config/niri/looknfeel.conf ;;
  *Screensaver*) open_in_editor ~/.config/karamel/branding/screensaver.txt ;;
  *About*) open_in_editor ~/.config/karamel/branding/about.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  karamel-launch-walker -m menus:karamelthemes --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(karamel-font-list)" "--width 350" "$(karamel-font-current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    karamel-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="îک¸  Audio\nï‡«  Wifi\nَ°‚¯  Bluetooth\nَ±گ‹  Power Profile\nَ°چ¹  Monitors"
  [ -f ~/.config/niri/bindings.conf ] && options="$options\nï„œ  Keybindings"
  [ -f ~/.config/niri/input.conf ] && options="$options\nî¾؛  Input"
  options="$options\nï’‰  Defaults\nَ°±”  DNS\nî¬‘  Security\nîک•  Config"

  case $(menu "Setup" "$options") in
  *Audio*) karamel-launch-or-focus-tui wiremix ;;
  *Wifi*) karamel-launch-wifi ;;
  *Bluetooth*) karamel-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *Monitors*) open_in_editor ~/.config/niri/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.config/niri/bindings.conf ;;
  *Input*) open_in_editor ~/.config/niri/input.conf ;;
  *Defaults*) open_in_editor ~/.config/uwsm/default ;;
  *DNS*) present_terminal karamel-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(karamel-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ "$profile" == "CNCLD" || -z "$profile" ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_config_menu() {
  case $(menu "Setup" "ïچ™  Niri\nïچ™  Swayidle\nïچ™  Swaylock\nïچ™  Wlsunset\nïچ‌  Swayosd\nَ°Œ§  Walker\nَ°چœ  Waybar\nَ°‍…  XCompose") in
  *Niri*) open_in_editor ~/.config/niri/niri.conf ;;
  *Swayidle*) open_in_editor ~/.config/niri/swayidle.conf && karamel-restart-swayidle ;;
  *Swaylock*) open_in_editor ~/.config/niri/swaylock.conf ;;
  *Wlsunset*) open_in_editor ~/.config/niri/wlsunset.conf && karamel-restart-wlsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && karamel-restart-swayosd ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && karamel-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && karamel-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && karamel-restart-xcompose ;;
  *) show_main_menu ;;
  esac
}

show_setup_security_menu() {
  case $(menu "Setup" "َ°ˆ·  Fingerprint\nî¬‘  Fido2") in
  *Fingerprint*) present_terminal karamel-setup-fingerprint ;;
  *Fido2*) present_terminal karamel-setup-fido2 ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "َ°£‡  Package\nَ°£‡  AUR\nï‰¨  Web App\nï’‰  TUI\nï’‡  Service\nî¯ڈ  Style\nَ°µ®  Development\nï…œ  Editor\nï’‰  Terminal\nَ±ڑ¤  AI\nَ°چ²  Windows\nï„›  Gaming") in
  *Package*) terminal karamel-pkg-install ;;
  *AUR*) terminal karamel-pkg-aur-install ;;
  *Web*) present_terminal karamel-webapp-install ;;
  *TUI*) present_terminal karamel-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *AI*) show_install_ai_menu ;;
  *Windows*) present_terminal "karamel-windows-vm install" ;;
  *Gaming*) show_install_gaming_menu ;;
  *) show_main_menu ;;
  esac
}

show_install_service_menu() {
  case $(menu "Install" "îœ‡  Dropbox\nï’‡  Tailscale\nَ°ںµ  Bitwarden\nîں°  Chromium Account") in
  *Dropbox*) present_terminal karamel-install-dropbox ;;
  *Tailscale*) present_terminal karamel-install-tailscale ;;
  *Bitwarden*) install_and_launch "Bitwarden" "bitwarden bitwarden-cli" "bitwarden" ;;
  *Chromium*) present_terminal karamel-install-chromium-google-account ;;
  *) show_install_menu ;;
  esac
}

show_install_editor_menu() {
  case $(menu "Install" "î£ڑ  VSCode\nï…œ  Cursor\nï…œ  Zed\nï…œ  Sublime Text\nï…œ  Helix\nï…œ  Emacs") in
  *VSCode*) present_terminal karamel-install-vscode ;;
  *Cursor*) install_and_launch "Cursor" "cursor-bin" "cursor" ;;
  *Zed*) present_terminal "echo 'Installing Zed...'; sudo pacman -S zed && setsid gtk-launch dev.zed.Zed" ;;
  *Sublime*) install_and_launch "Sublime Text" "sublime-text-4" "sublime_text" ;;
  *Helix*) install "Helix" "helix" ;;
  *Emacs*) install "Emacs" "emacs-wayland" && systemctl --user enable --now emacs.service ;;
  *) show_install_menu ;;
  esac
}

show_install_terminal_menu() {
  case $(menu "Install" "ï’‰  Alacritty\nï’‰  Ghostty\nï’‰  Kitty") in
  *Alacritty*) install_terminal "alacritty" ;;
  *Ghostty*) install_terminal "ghostty" ;;
  *Kitty*) install_terminal "kitty" ;;
  *) show_install_menu ;;
  esac
}

show_install_ai_menu() {
  ollama_pkg=$(
    (command -v nvidia-smi &>/dev/null && echo ollama-cuda) ||
      (command -v rocminfo &>/dev/null && echo ollama-rocm) ||
      echo ollama
  )

  case $(menu "Install" "َ±ڑ¤  Claude Code\nَ±ڑ¤  Cursor CLI\nَ±ڑ¤  Gemini\nَ±ڑ¤  OpenAI Codex\nَ±ڑ¤  LM Studio\nَ±ڑ¤  Ollama\nَ±ڑ¤  Crush\nَ±ڑ¤  opencode") in
  *Claude*) install "Claude Code" "claude-code" ;;
  *Cursor*) install "Cursor CLI" "cursor-cli" ;;
  *OpenAI*) install "OpenAI Codex" "openai-codex-bin" ;;
  *Gemini*) install "Gemini" "gemini-cli" ;;
  *Studio*) install "LM Studio" "lmstudio" ;;
  *Ollama*) install "Ollama" $ollama_pkg ;;
  *Crush*) install "Crush" "crush-bin" ;;
  *opencode*) install "opencode" "opencode" ;;
  *) show_install_menu ;;
  esac
}

