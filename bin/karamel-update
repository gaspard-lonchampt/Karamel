#!/bin/bash

set -e

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://karamel.org/discord\033[0m"' ERR

if [[ $1 == "-y" ]] || karamel-update-confirm; then
  karamel-update-without-idle
  karamel-snapshot create || [ $? -eq 127 ]
  karamel-update-git
  karamel-update-perform
fi
