# Changes require a restart to take effect.

# Ensure Karamel bins are in the path
export KARAMEL_PATH=$HOME/.local/share/karamel
export PATH=$KARAMEL_PATH/bin:$PATH

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
karamel-cmd-present mise && eval "$(mise activate bash)"
