# Karamel Swaylock Configuration

# Appearance
color=1a1b26
font=JetBrains Mono Nerd Font
font-size=24

# Clock
clock
timestr=%H:%M
datestr=%A, %d %B

# Indicator
indicator
indicator-radius=120
indicator-thickness=10

# Colors (Tokyo Night theme - can be overridden by theme)
inside-color=1a1b26
inside-clear-color=1a1b26
inside-ver-color=1a1b26
inside-wrong-color=1a1b26

ring-color=7aa2f7
ring-clear-color=bb9af7
ring-ver-color=7dcfff
ring-wrong-color=f7768e

line-color=00000000
line-clear-color=00000000
line-ver-color=00000000
line-wrong-color=00000000

separator-color=00000000

key-hl-color=9ece6a
bs-hl-color=f7768e

text-color=c0caf5
text-clear-color=c0caf5
text-ver-color=c0caf5
text-wrong-color=f7768e

# Effects
effect-blur=20x5
effect-vignette=0.5:0.5
fade-in=0.2

# Grace period
grace=2
grace-no-mouse
grace-no-touch

# Behavior
ignore-empty-password
show-failed-attempts
daemonize
